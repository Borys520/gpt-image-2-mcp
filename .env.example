# ----- required -----
# Your OpenAI API key. The org must be verified to use gpt-image-2.
OPENAI_API_KEY=sk-...

# ----- optional: OpenAI client -----
# Base URL override (e.g. for an OpenAI-compatible proxy)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Explicit org / project to bill against
# OPENAI_ORG_ID=org-...
# OPENAI_PROJECT_ID=proj_...

# ----- optional: image output -----
# Where generated images are written. Defaults to:
#   $XDG_CONFIG_HOME/gpt-image-2-mcp/output/<project>-<hash>/   (Linux/macOS)
#   $APPDATA/gpt-image-2-mcp/output/<project>-<hash>/            (Windows)
# Absolute or relative (resolved from CWD).
# GPT_IMAGE_2_OUTPUT_DIR=./output

# Allow writing to OS-sensitive directories (/etc, ~/.ssh, etc.).
# Off by default. Only set if you know what you're doing.
# GPT_IMAGE_2_ALLOW_UNSAFE_OUTPUT_DIR=0

# ----- optional: edit-session caps -----
# Max concurrent in-memory edit sessions (LRU evicted beyond this).
# GPT_IMAGE_2_SESSION_MAX=20

# Idle TTL in ms before a session is swept.
# GPT_IMAGE_2_SESSION_TTL_MS=3600000

# ----- optional: edit-endpoint routing -----
# OpenAI's /v1/images/edits currently rejects gpt-image-2 (day-2 bug).
# We route edits through the Responses API image_generation tool.
# Set to 1 to test the direct endpoint once OpenAI ships the fix.
# OPENAI_USE_DIRECT_EDITS=0

# Host model used by the Responses-API edit route.
# OPENAI_RESPONSES_EDIT_MODEL=gpt-4.1-mini

# ----- optional: logging -----
# Set to 1 for verbose debug logs on stderr.
# GPT_IMAGE_2_MCP_DEBUG=0
